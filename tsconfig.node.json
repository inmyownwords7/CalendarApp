{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,

    "rootDir": "src",
    "outDir": "dist/node",

    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/node/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/gas/**"]
}
